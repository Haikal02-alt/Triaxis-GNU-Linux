1 Install Distrobox sudo apt install distrobox sudo dnf install distrobox or sudo pacman -S distrobox
2 distrobox-create --name Triaxis --image archlinux:latest
3 Run distrobox enter Triaxis
4 sudo pacman -S fastfetch nano
5 Run sudo nano /etc/os-release then change
